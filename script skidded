-- ==========================================

local isToggledActive = false
local lastKeybindState = false
local flyBodyVelocity, flyBodyGyro

RunService.RenderStepped:Connect(function()
    local camera = workspace.CurrentCamera
    if not camera then return end

    if FOVCircle.Visible then
        FOVCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    end

    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if char and hum and hrp then
        if CustomSpeedEnabled then hum.WalkSpeed = CustomSpeedValue else hum.WalkSpeed = 16 end
        if CustomJumpEnabled then hum.JumpPower = CustomJumpValue else hum.JumpPower = 50 end

        if NoclipEnabled or FlingMasterEnabled then
            for _, part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end

        -- FLY LOGIC
        if FlyEnabled and not FlingMasterEnabled then
            if not flyBodyVelocity or flyBodyVelocity.Parent ~= hrp then
                flyBodyVelocity = Instance.new("BodyVelocity")
                flyBodyVelocity.MaxForce = Vector3.new(1, 1, 1) * math.huge
                flyBodyVelocity.Parent = hrp
                
                flyBodyGyro = Instance.new("BodyGyro")
                flyBodyGyro.MaxTorque = Vector3.new(1, 1, 1) * math.huge
                flyBodyGyro.CFrame = camera.CFrame
                flyBodyGyro.Parent = hrp
            end

            local moveDirection = hum.MoveDirection
            local camCFrame = camera.CFrame
            flyBodyGyro.CFrame = camCFrame

            local velocityVector = Vector3.new(0,0,0)
            if moveDirection.Magnitude > 0 then
                local forwardVector = camCFrame.LookVector
                local rightVector = camCFrame.RightVector
                
                local inputVector = Vector3.new(
                    moveDirection:Dot(rightVector),
                    0,
                    moveDirection:Dot(camCFrame.LookVector)
                )
                
                velocityVector = (forwardVector * inputVector.Z + rightVector * inputVector.X).Unit * FlySpeed
            end
            
            flyBodyVelocity.Velocity = velocityVector
        else
            if flyBodyVelocity then flyBodyVelocity:Destroy() flyBodyVelocity = nil end
            if flyBodyGyro then flyBodyGyro:Destroy() flyBodyGyro = nil end
        end
    end

    -- AIMBOT LOGIC
    if not Options or not Options.AimKeybind or not AimAssistEnabled then 
        isToggledActive = false
        CurrentLockedTarget = nil
        return 
    end

    local currentKeybindState = Options.AimKeybind:GetState()
    local trackingTargetActive = false

    if AimTriggerMode == "Hold" then
        trackingTargetActive = currentKeybindState
        if not trackingTargetActive then CurrentLockedTarget = nil end
    elseif AimTriggerMode == "Toggle" then
        if currentKeybindState and not lastKeybindState then
            isToggledActive = not isToggledActive
        end
        trackingTargetActive = isToggledActive
        if not trackingTargetActive then CurrentLockedTarget = nil end
    end
    lastKeybindState = currentKeybindState

    if trackingTargetActive then
        if not CurrentLockedTarget or not isValidTarget(CurrentLockedTarget) then
            CurrentLockedTarget = getClosestPlayerToCenter()
        end
        
        if CurrentLockedTarget and CurrentLockedTarget.Character then
            local targetChar = CurrentLockedTarget.Character
            local targetPart = targetChar:FindFirstChild("Head") or targetChar:FindFirstChild("HumanoidRootPart")
            local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
            
            if targetPart and targetHRP then
                local targetPosition = targetPart.Position
                local targetVelocity = targetHRP.AssemblyLinearVelocity
                local predictedPosition = targetPosition + (targetVelocity * PredictionVelocityFactor)
                
                local targetLookCFrame = CFrame.lookAt(camera.CFrame.Position, predictedPosition)
                camera.CFrame = camera.CFrame:Lerp(targetLookCFrame, AimSmoothing)
            end
        end
    end
end)



