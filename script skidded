-- Persistent Flight Logic
task.spawn(function()
    while true do
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if getgenv().FarmEnabled and root then
            -- 1. Locate Murderer
            local murderer = nil
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character and (p.Character:FindFirstChild("Knife") or p:GetAttribute("Role") == "Murderer") then
                    murderer = p.Character
                    MurdererLabel:SetText('Current Murderer: ' .. p.Name)
                    break
                end
            end

            -- 2. Target Selection with Murderer Avoidance
            local availableCoins = {}
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name == "MainCoin" and v:IsA("BasePart") and not BlacklistedCoins[v] then
                    table.insert(availableCoins, v)
                end
            end
            CoinCountLabel:SetText('Coins Remaining: ' .. #availableCoins)

            -- Pick coin (skip if murderer is in the way)
            if not currentTargetCoin or not currentTargetCoin.Parent then
                local bestCoin = nil
                local dist = math.huge
                for _, v in pairs(availableCoins) do
                    local d = (root.Position - v.Position).Magnitude
                    -- Avoidance Logic: Check if murderer is between us and the coin
                    if getgenv().AvoidMurderer and murderer and murderer:FindFirstChild("HumanoidRootPart") then
                        local mPos = murderer.HumanoidRootPart.Position
                        local toCoin = (v.Position - root.Position).Unit
                        local toMurderer = (mPos - root.Position).Unit
                        -- If the angle is small, the murderer is roughly in the direction of the coin
                        if (toCoin:Dot(toMurderer) > 0.8) and (mPos - root.Position).Magnitude < (v.Position - root.Position).Magnitude then
                            continue -- Skip this coin
                        end
                    end
                    if d < dist then bestCoin = v; dist = d end
                end
                currentTargetCoin = bestCoin
            end

            -- 3. Flight
            if currentTargetCoin and currentTargetCoin.Parent then
                for _, part in pairs(char:GetChildren()) do if part:IsA("BasePart") then part.CanCollide = false end end
                bodyVel.Parent = root
                bodyVel.Velocity = (currentTargetCoin.Position - root.Position).Unit * getgenv().FarmSpeed
                
                if (root.Position - currentTargetCoin.Position).Magnitude < 5 then
                    BlacklistedCoins[currentTargetCoin] = true
                    task.spawn(function() task.wait(1.5) BlacklistedCoins[currentTargetCoin] = nil end)
                    currentTargetCoin = nil
                end
            else
                bodyVel.Parent = nil
            end
        else
            bodyVel.Parent = nil
        end
        task.wait(0.1)
    end
end)


