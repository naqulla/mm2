local function getPlayerRoleColor(player)
    local character = player.Character
    local backpack = player:FindFirstChild("Backpack")
    
    local hasKnife = (character and character:FindFirstChild("Knife")) or (backpack and backpack:FindFirstChild("Knife"))
    local hasGun = (character and character:FindFirstChild("Gun")) or (backpack and backpack:FindFirstChild("Gun"))
    
    if hasKnife then
        return MurdererColor
    elseif hasGun then
        return SheriffColor
    else
        return CrewmateColor
    end
end

local function clearESP()
    for name, highlight in pairs(Highlights) do
        if highlight and highlight.Parent then
            pcall(function() highlight:Destroy() end)
        end
    end
    table.clear(Highlights)

    for gunItem, highlight in pairs(DroppedGunHighlights) do
        if highlight and highlight.Parent then
            pcall(function() highlight:Destroy() end)
        end
    end
    table.clear(DroppedGunHighlights)
end

local function updateESP()
    if RoleESPEnabled then
        local currentActivePlayers = {}

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                currentActivePlayers[player.Name] = true
                local char = player.Character

                if char and char.Parent == workspace and char:FindFirstChild("HumanoidRootPart") then
                    local color = getPlayerRoleColor(player)
                    local highlight = Highlights[player.Name]
                    
                    if not highlight or not highlight.Parent or highlight.Parent ~= char then
                        if highlight then pcall(function() highlight:Destroy() end) end
                        
                        highlight = Instance.new("Highlight")
                        highlight.Name = "Admin_ESP_Highlight"
                        highlight.Parent = char
                        Highlights[player.Name] = highlight
                    end
                    
                    highlight.FillColor = color
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.FillTransparency = 0.5
                    highlight.OutlineTransparency = 0
                    highlight.Enabled = true
                end
            end
        end

        for cachedName, highlight in pairs(Highlights) do
            if not currentActivePlayers[cachedName] then
                if highlight and highlight.Parent then pcall(function() highlight:Destroy() end) end
                Highlights[cachedName] = nil
            end
        end
    else
        for name, highlight in pairs(Highlights) do
            if highlight and highlight.Parent then pcall(function() highlight:Destroy() end) end
            Highlights[name] = nil
        end
    end

    if GunESPEnabled then
        local currentGuns = {}

        -- FIX: GetDescendants instead of GetChildren so nested/foldered guns are found
        for _, item in ipairs(workspace:GetDescendants()) do
            if item:IsA("Tool") and item.Name == "Gun" then
                local handle = item:FindFirstChild("Handle")

                -- FIX: only proceed if there's actually a part to highlight
                if handle then
                    currentGuns[item] = true
                    local gunHighlight = DroppedGunHighlights[item]

                    -- FIX: parent highlight to Handle, not the Tool itself
                    if not gunHighlight or not gunHighlight.Parent or gunHighlight.Parent ~= handle then
                        if gunHighlight then pcall(function() gunHighlight:Destroy() end) end

                        gunHighlight = Instance.new("Highlight")
                        gunHighlight.Name = "Admin_Gun_Highlight"
                        gunHighlight.Parent = handle
                        DroppedGunHighlights[item] = gunHighlight
                    end

                    gunHighlight.FillColor = DroppedGunColor
                    gunHighlight.OutlineColor = DroppedGunColor
                    gunHighlight.FillTransparency = 0.5
                    gunHighlight.OutlineTransparency = 0
                    gunHighlight.Enabled = true
                end
            end
        end

        for gunItem, highlight in pairs(DroppedGunHighlights) do
            if not currentGuns[gunItem] then
                if highlight and highlight.Parent then pcall(function() highlight:Destroy() end) end
                DroppedGunHighlights[gunItem] = nil
            end
        end
    else
        for gunItem, highlight in pairs(DroppedGunHighlights) do
            if highlight and highlight.Parent then pcall(function() highlight:Destroy() end) end
            DroppedGunHighlights[gunItem] = nil
        end
    end
end

local function isValidTarget(player)
    if not player or not player.Character or player == LocalPlayer then return false end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    
    if not hrp or not humanoid or humanoid.Health <= 0 then return false end
    
    local roleColor = getPlayerRoleColor(player)
    if TargetRoleFilter == "Murderer Only" and roleColor ~= MurdererColor then return false end
    if TargetRoleFilter == "Sheriff Only" and roleColor ~= SheriffColor then return false end
    
    return true
end

local function getClosestPlayerToCenter()
    local camera = workspace.CurrentCamera
    if not camera then return nil end
    
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local closestPlayer = nil
    local shortestDistance = math.huge
    
    for _, player in ipairs(Players:GetPlayers()) do
        if isValidTarget(player) then
            local targetPart = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("HumanoidRootPart")
            if targetPart then
                local screenPos, onScreen = camera:WorldToScreenPoint(targetPart.Position)
                
                if onScreen then
                    local playerScreenVector = Vector2.new(screenPos.X, screenPos.Y)
                    local distance = (playerScreenVector - screenCenter).Magnitude
                    
                    if distance < shortestDistance and distance <= AimFOVRadius then
                        shortestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end
    return closestPlayer
end

